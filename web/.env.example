# WebSocket of the always-on Claude brain (agent_service/server.py)
VITE_AGENT_WS=ws://localhost:8770/chat

# Optional: URL of a running norma-core station-viewer, embedded in the Cameras card
# for live cameras + calibration. Leave blank to show the placeholder.
VITE_VIEWER_URL=

# Voice mode (ElevenLabs streaming TTS). Browser-direct — runs fully in parallel
# with the brain; leave the key blank to disable voice output. STT uses the
# browser's built-in Web Speech API (Chrome/Edge), no key needed.
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
VITE_ELEVENLABS_MODEL=eleven_turbo_v2_5

# Optional parallel "narrator": a fast LLM that turns the robot's actions into
# warm spoken commentary (voiced by ElevenLabs above). Runs fully decoupled from
# the brain. Leave the key blank to fall back to simple built-in action cues.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini   # or gpt-4.1-nano for the fastest/cheapest
