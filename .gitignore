# --- Cloned upstream dependency (NOT vendored into this repo) ---
# norma-core is NormaCore's own GitHub repo with its own git history.
# Clone it separately (see root README). We only reference it.
norma-core/

# --- Local agent / editor config ---
.claude/*
!.claude/skills/
.idea/
.vscode/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# --- Node (for the future web app) ---
node_modules/
dist/
build/
.next/

# --- Env / secrets ---
.env
.env.*
!.env.example

# --- OS / misc ---
.DS_Store
Thumbs.db
*.swp
*.log

# Playwright MCP browser session artifacts
.playwright-mcp/

# Stray root-level screenshots (put intentional images in docs/assets/)
/*.png

# --- Calibration artifacts (per-rig; generated by station_mcp/calibrate.py) ---
station_mcp/calib_frames/
station_mcp/waypoints.partial.json
# waypoints.json is rig-specific calibration output; force-add it (git add -f) if you
# deliberately want to commit a demo machine's grid.
station_mcp/waypoints.json
