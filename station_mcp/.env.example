# Address of the NormaCore Station (the calibrated robot host). LEAVE UNSET to run in MOCK mode.
STATION_HOST=
STATION_PORT=8888

# Path to the cloned norma-core repo (needed for station_py + generated protobufs in LIVE mode).
NORMA_CORE_PATH=../norma-core

# Pin which ST3215 bus/arm to read + command. A leader+follower rig exposes TWO buses; leave
# blank to auto-pick the most-calibrated bus, or set the serial (printed by get_state / server
# logs) to force a specific arm — e.g. STATION_BUS_SERIAL=5B3E090142
STATION_BUS_SERIAL=

# Force mock even if STATION_HOST is set (1/true/yes).
MOCK=

# Optional: a JPEG/PNG served by look() in mock mode (else a generated placeholder is used).
MOCK_FRAME_PATH=

# Stage-1 SmolVLA retry count.
VLA_MAX_TRIES=3
